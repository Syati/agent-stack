#!/bin/sh
set -eu

fix_docker_socket_group() {
  sock=/var/run/docker.sock
  [ -S "$sock" ] || return 0

  sock_gid=$(stat -c '%g' "$sock")
  [ "$sock_gid" != "0" ] || return 0

  group_name=$(getent group "$sock_gid" | cut -d: -f1)
  if [ -z "$group_name" ]; then
    group_name=docker-host
    groupadd -g "$sock_gid" "$group_name"
  fi

  usermod -aG "$group_name" agent
}

fix_mise_dirs() {
  install -d -o agent -g agent /home/agent/.local
  install -d -o agent -g agent /home/agent/.local/share
  install -d -o agent -g agent /home/agent/.local/share/mise
  chown -R agent:agent /home/agent/.local/share/mise
}

start_tcp_bridges() {
  bridges=${AGENT_TCP_BRIDGES:-}
  if [ -z "$bridges" ]; then
    return 0
  fi

  old_ifs=$IFS
  IFS=','
  set -- $bridges
  IFS=$old_ifs

  for bridge in "$@"; do
    bridge=$(printf '%s' "$bridge" | tr -d '[:space:]')
    [ -n "$bridge" ] || continue

    listen=${bridge%%->*}
    target=${bridge#*->}
    if [ "$listen" = "$bridge" ] || [ -z "$listen" ] || [ -z "$target" ]; then
      echo "agent-entrypoint: invalid AGENT_TCP_BRIDGES entry: $bridge" >&2
      continue
    fi

    listen_host=${listen%:*}
    listen_port=${listen##*:}
    target_host=${target%:*}
    target_port=${target##*:}

    if [ -z "$listen_host" ] || [ -z "$listen_port" ] || [ -z "$target_host" ] || [ -z "$target_port" ]; then
      echo "agent-entrypoint: invalid AGENT_TCP_BRIDGES entry: $bridge" >&2
      continue
    fi

    socat "TCP-LISTEN:${listen_port},bind=${listen_host},fork,reuseaddr" "TCP:${target_host}:${target_port}" &
  done
}

ensure_mise_tools() {
  if ! command -v mise >/dev/null 2>&1; then
    return 0
  fi

  if mise which fzf >/dev/null 2>&1; then
    return 0
  fi

  mise use -g fzf@latest >/dev/null
}

if [ "$(id -u)" = "0" ]; then
  fix_docker_socket_group
  fix_mise_dirs
  exec gosu agent "$0" "$@"
fi

start_tcp_bridges
ensure_mise_tools
exec "$@"
